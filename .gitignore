# ============================================================
# agentsHQ — .gitignore
# ============================================================

# ── Python ───────────────────────────────────────────────────
*.pyc
*.pyo
__pycache__/
*.egg-info/
dist/
build/
.venv/
venv/
env/

# ── Environment & Secrets ────────────────────────────────────
# NEVER commit any file containing real secrets.
# Only commit *.template or *.example files as placeholders.
.env
.env.*
*.env
*.env.txt
*.env.bak
*.env.old
*.env.local
*.env.production
*.env.staging
*.env.development
secrets.json
secrets.yaml
secrets.yml

# ── Log files ─────────────────────────────────────────────────
logs/
*.log
**/console-*.log
**/.playwright-mcp/

# ── Data directories ─────────────────────────────────────────
postgres_data/
qdrant_data/
.qdrant_data/
waha_sessions/

# ── Output directories ───────────────────────────────────────
agent_outputs/
outputs/

# ── Archive (contains old .env files — never commit) ─────────
zzzArchive/

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ── Docker volumes ───────────────────────────────────────────
volumes/

# ── Scratch / temp scripts ───────────────────────────────────
tmp/

# ── Compiled binaries / local tools ─────────────────────────
tools/

# ── detect-secrets baseline ───────────────────────────────────
.secrets.baseline

# ── Hookify local rules (project-specific, never commit) ──────
.claude/*.local.md

# ── Superpowers plugin skills (managed by Claude Code plugin, not this repo) ──
skills/superpowers/

# ── Superpowers generated plan files ─────────────────────────
docs/superpowers/plans/

# ── Superpowers brainstorm sessions (ephemeral) ──────────────
.superpowers/

# Google service account key — never commit
secrets/

.vercel
node_modules
output
search_output.txt

# ── thepopebot runtime data (SQLite, workspaces, sessions) ───
# These are committed by the rebuild workflow from inside the container
# where /project = /root/agentsHQ/thepopebot, so paths are repo-root relative
data/db/
data/workspaces/
data/clusters/
.tmp/
thepopebot/data/db/
thepopebot/data/workspaces/
thepopebot/data/clusters/
thepopebot/.tmp/
thepopebot/logs/

# ── Local scratch / runtime files ────────────────────────────
ideas_full_list.txt
ideas_full_list_utf8.txt
test_sankofa.py
data/
docs/research/

# ── Temp uploads (audio, video, chunks — never commit) ───────
tmp_upload/
*.mp3
*.mp4
*.wav
*.chunk

# Runtime deploy state
.deploy-sha
.secrets.baseline.new

docs/design-references/*.md
!docs/design-references/INDEX.md
docs/design-decisions/

# IDE and tooling directories
.windsurf/
.agents/

# External community skill library (cloned separately on each machine, not managed here)
skills/community/

# Hyperframes skill registry lock (external tool, content hashes flagged as false positives)
skills-lock.json
