# ============================================================
# agentsHQ — .gitignore
# ============================================================

# Local git worktrees (per superpowers:using-git-worktrees skill)
.worktrees/

# ── Python ───────────────────────────────────────────────────
*.pyc
*.pyo
__pycache__/
*.egg-info/
dist/
build/
.venv/
venv/
env/

# ── Environment & Secrets ────────────────────────────────────
# NEVER commit any file containing real secrets.
# Only commit *.template or *.example files as placeholders.
.env
.env.*
*.env
*.env.txt
*.env.bak
*.env.old
*.env.local
*.env.production
*.env.staging
*.env.development
secrets.json
secrets.yaml
secrets.yml

# ── Log files ─────────────────────────────────────────────────
logs/
*.log
**/console-*.log
**/.playwright-mcp/

# ── Data directories ─────────────────────────────────────────
postgres_data/
qdrant_data/
.qdrant_data/
waha_sessions/

# Autonomy runtime state (kill switch, crew flags)
data/autonomy_state.json

# ── Output directories ───────────────────────────────────────
agent_outputs/
# outputs/ removed 2026-05-02: contents migrated to agent_outputs/ to align with AGENTS_OUTPUT_DIR + docker-compose mount name

# ── Archive (contains old .env files — never commit) ─────────
zzzArchive/

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ── Docker volumes ───────────────────────────────────────────
volumes/

# ── Scratch / temp scripts ───────────────────────────────────
tmp/

# ── Compiled binaries / local tools ─────────────────────────
tools/

# ── detect-secrets baseline ───────────────────────────────────
.secrets.baseline

# ── Hookify local rules (project-specific, never commit) ──────
.claude/*.local.md

# ── Superpowers plugin skills (managed by Claude Code plugin, not this repo) ──
skills/superpowers/

# ── Superpowers generated plan files ─────────────────────────
docs/superpowers/plans/

# ── Superpowers brainstorm sessions (ephemeral) ──────────────
.superpowers/

# Google service account key — never commit
secrets/

.vercel
node_modules
output
search_output.txt

# ── thepopebot runtime data (SQLite, workspaces, sessions) ───
# These are committed by the rebuild workflow from inside the container
# where /project = /root/agentsHQ/thepopebot, so paths are repo-root relative
data/db/
data/workspaces/
data/clusters/
.tmp/
thepopebot/data/db/
thepopebot/data/workspaces/
thepopebot/data/clusters/
thepopebot/.tmp/
thepopebot/logs/

# ── Local scratch / runtime files ────────────────────────────
ideas_full_list.txt
ideas_full_list_utf8.txt
test_sankofa.py
test_mermaid.py
*.md.bak
data/
docs/research/

# ── Temp uploads (audio, video, chunks — never commit) ───────
tmp_upload/
*.mp3
*.mp4
*.wav
*.chunk

# Runtime deploy state
.deploy-sha
.secrets.baseline.new

docs/design-references/*.md
!docs/design-references/INDEX.md
docs/design-decisions/

# IDE and tooling directories
.windsurf/
.agents/

# External community skill library (cloned separately on each machine, not managed here)
skills/community/

# Hyperframes skill registry lock (external tool, content hashes flagged as false positives)
skills-lock.json
.claude/worktrees/

# Ephemeral scratch scripts — diagnostic/probe code, never committed
scratch/

# Codex SSH working directory — contains private keys and probes, NEVER commit
codex_ssh/
.codex_ssh/

# Runtime workspace for article drafts, media outputs, probes
workspace/
workspace/memory-index/*
!workspace/memory-index/.gitkeep

# Sandbox throwaway corner (sandbox/ itself IS tracked for in-flight work)
sandbox/.tmp/

# shadcn cache snapshots (regenerable via skills/ui-styling/scripts/refresh-shadcn-cache.sh)
skills/ui-styling/cache/*
!skills/ui-styling/cache/.gitkeep

# Machine-local tooling config (tmux, etc.)
config/

# Vendored external tool clones (CLI-Anything, OpenSpace, etc.)
# Moved 2026-05-02 from `external/` to `docs/research/external-references/` per Compass governance: research artifacts belong in docs/.
docs/research/external-references/

# Claude Code scheduling skill runtime lock
.claude/scheduled_tasks.lock
skills/notebooklm/
a-b testing.xlsx
signal_works/draft_payloads.json
apollo_pricing.png
download.html

# Codex companion local progress tracker
.codex-task-progress.txt

# Pytest local tmp directories (created by tests in some sandboxes)
pytest_tmp/
pytest_tmp_work/
.pytest-tmp/

# Codex sandbox progress fallback artifact
# Moved 2026-05-02 from root `task_progress/` to `data/codex/` per Compass governance: runtime ephemera belongs under data/.
data/codex/
configs/asset_vault.json
